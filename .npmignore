# Source files (we only want compiled JS)
src/
*.ts
!lib/**/*.d.ts

# Test files
test/
*.spec.ts
*.spec.js
*.test.ts
*.test.js
coverage/

# Development files
.git/
.gitignore
.idea/
.vscode/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# dist/ and build/ are NOT listed here: package.json "files" ships dist/; ignoring them
# would empty the published tarball (see docs/superpowers/specs/2026-04-25-npm-public-publish-design.md).

# Dependencies
node_modules/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE files
*.swp
*.swo
*~

