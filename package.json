{
  "name": "nestjs-aws-pubsub",
  "version": "0.0.1",
  "description": "NestJS microservice transport for AWS SQS and SNS with pub/sub patterns, featuring message acknowledgment, batch processing, retry logic, and SNS fan-out support.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/akeebismail/nestjs-aws-pubsub.git"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf lib/*.js lib/*.d.ts lib/*.js.map"
  },
  "keywords": [
    "nestjs",
    "aws",
    "sqs",
    "sns",
    "pubsub",
    "microservice",
    "transport",
    "messaging",
    "queue",
    "events"
  ],
  "author": "Akeeb Ismail",
  "license": "ISC",
  "devDependencies": {
    "@nestjs/testing": "^11.1.19",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@aws-sdk/client-sns": "^3.1037.0",
    "@aws-sdk/client-sqs": "^3.1037.0",
    "@nestjs/mapped-types": "*",
    "sqs-consumer": "^14.2.8",
    "sqs-producer": "^8.0.9"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/microservices": "^11.1.6"
  }
}
